# API Configuration
# Production: https://api.sokosumi.com
# Preprod: https://api.preprod.sokosumi.com
SOKOSUMI_API_URL=https://api.sokosumi.com

# Optional overrides for browser-based auth handoff
# Web App default is derived from SOKOSUMI_API_URL (api.sokosumi.com -> sokosumi.com)
# Auth default is derived as <web>/api/auth
# SOKOSUMI_WEB_URL=https://sokosumi.com
# SOKOSUMI_AUTH_URL=https://sokosumi.com/api/auth

# Authentication
# Both API keys and auth tokens are sent as Bearer tokens per OpenAPI spec
# Option 1: API Key
# First-run CLI setup can store this automatically in ~/.sokosumi/config.json
# SOKOSUMI_API_KEY=<your-sokosumi-api-key>

# Option 2: Auth Token (managed automatically after login via CLI)
# This is stored in ~/.sokosumi/credentials.json after authentication
# SOKOSUMI_AUTH_TOKEN=your-auth-token-here

# Optional: Anthropic API Key for AI features
ANTHROPIC_API_KEY=<your-anthropic-api-key>
